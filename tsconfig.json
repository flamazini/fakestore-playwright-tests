{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "moduleResolution": "node10",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["src", "tests", "mock-server", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}